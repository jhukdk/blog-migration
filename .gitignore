# --- Terraform / infra secrets & state (never commit) ---
*.tfstate
*.tfstate.*
*.tfvars
*.tfvars.json
.terraform/

# Partial backend config holds the state-bucket name (account-ID bearing); keep
# it local. Use backend.hcl.example as the committed template.
backend.hcl
crash.log
crash.*.log

# --- AWS credentials ---
.aws/

# --- Environment / secrets ---
.env
.env.*
*.env
*.pem

# --- Hugo build artifacts ---
/site/public/
/site/resources/
/site/.hugo_build.lock

# --- Python virtualenv (migration tooling) ---
.venv/

# --- Raw WordPress export (large input; converted output lives in /site) ---
# Remove this line if you want the WXR export + uploads tracked for reproducibility.
migration-source/

# --- OS / editor cruft ---
.DS_Store
*.swp
